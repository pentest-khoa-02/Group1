generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  email     String     @unique
  password  String
  posts     Post[]
  stories     Story[]
  user_info User_info?
}

model User_info {
  id         Int    @id @default(autoincrement())
  firstname  String
  lastname   String
  university String
  live       String
  job        String
  userid     Int    @unique
  user       User   @relation(fields: [userid], references: [id])
}

model Post {
  id        Int      @id @default(autoincrement())
  userId  Int
  content   String
  create_at DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id])
  photos Photo[]
  videos Video[]
}

model Story {
  id         Int      @id @default(autoincrement())
  userId   Int
  content    String
  create_at  DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  photos Photo[]
  videos Video[]
}

model Photo {
  id    Int    @id @default(autoincrement())
  url   String
  postId Int?
  post Post?    @relation(fields: [postId], references: [id])
  storyId Int?
  story Story?   @relation(fields: [storyId], references: [id])
}

model Video {
  id    Int    @id @default(autoincrement())
  url   String
  postId Int?
  post Post?   @relation(fields: [postId], references: [id])
  storyId Int?
  story Story?    @relation(fields: [storyId], references: [id])
}

model Message {
  id            Int      @id @default(autoincrement())
  senderId      Int
  receiverId    Int
  messsage_text String
  create_at     DateTime @default(now())
}
